# Server
KIROCLI_GO_ADDR=:8089
KIROCLI_GO_READ_TIMEOUT_SEC=15
KIROCLI_GO_WRITE_TIMEOUT_SEC=60
KIROCLI_GO_IDLE_TIMEOUT_SEC=90

# Admin / API auth
KIROCLI_GO_API_TOKEN=change_me

# Account source
# auto | env | csv | api
KIROCLI_GO_ACCOUNT_SOURCE=env

# env source
KIROCLI_GO_BEARER_TOKEN=

# csv source
KIROCLI_GO_ACCOUNTS_CSV=

# api source
KIROCLI_GO_ACCOUNT_API_URL=
KIROCLI_GO_ACCOUNT_API_TOKEN=
KIROCLI_GO_ACCOUNT_CATEGORY_ID=3
KIROCLI_GO_ACCOUNT_FETCH_COUNT=20
KIROCLI_GO_ACTIVE_POOL_SIZE=10
KIROCLI_GO_MAX_REFRESH_ATTEMPTS=3

# token refresh
KIROCLI_GO_OIDC_URL=https://oidc.us-east-1.amazonaws.com/token
KIROCLI_GO_REFRESH_TIMEOUT_SEC=30

# state files
KIROCLI_GO_ACCOUNT_STATE_PATH=data/accounts_state.json
KIROCLI_GO_STATS_STATE_PATH=data/stats_state.json
KIROCLI_GO_CATALOG_STATE_PATH=data/catalog_state.json

# background
KIROCLI_GO_MODEL_REFRESH_ENABLED=true
KIROCLI_GO_MODEL_REFRESH_ON_START=true
KIROCLI_GO_MODEL_REFRESH_INTERVAL_SEC=1800
KIROCLI_GO_MODEL_REFRESH_STARTUP_DELAY_SEC=5
KIROCLI_GO_TOKEN_POOL_ENABLED=true
KIROCLI_GO_TOKEN_POOL_WARM_ON_START=true
KIROCLI_GO_TOKEN_POOL_REFRESH_INTERVAL_SEC=1800
KIROCLI_GO_TOKEN_POOL_STARTUP_DELAY_SEC=3

# state persistence
KIROCLI_GO_STATE_PERSIST_ENABLED=true
KIROCLI_GO_STATE_PERSIST_INTERVAL_SEC=60

# models
KIROCLI_GO_THINKING_SUFFIX=-thinking

# upstream
KIROCLI_GO_CLI_BASE_URL=https://q.us-east-1.amazonaws.com/generateAssistantResponse
KIROCLI_GO_CLI_MODELS_URL=https://q.us-east-1.amazonaws.com?origin=KIRO_CLI
KIROCLI_GO_CLI_MCP_URL=https://q.us-east-1.amazonaws.com/mcp
KIROCLI_GO_CLI_TARGET=AmazonCodeWhispererStreamingService.GenerateAssistantResponse
KIROCLI_GO_CLI_MODELS_TARGET=AmazonCodeWhispererService.ListAvailableModels
KIROCLI_GO_CLI_ORIGIN=KIRO_CLI
KIROCLI_GO_CLI_TIMEOUT_SEC=300

# transport
KIROCLI_GO_PROXY_URL=
KIROCLI_GO_CLI_USER_AGENT=aws-sdk-rust/1.3.10 ua/2.1 api/codewhispererstreaming/0.1.12842 os/macos lang/rust/1.88.0 md/appVersion-1.23.1 app/AmazonQ-For-CLI
KIROCLI_GO_CLI_AMZ_USER_AGENT=aws-sdk-rust/1.3.10 ua/2.1 api/codewhispererstreaming/0.1.12842 os/macos lang/rust/1.88.0 m/F app/AmazonQ-For-CLI
